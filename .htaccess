<IfModule mod_headers.c>
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'self'"
</IfModule>

<IfModule mod_rewrite.c>
RewriteEngine On

RewriteRule ^sitemap\.xml$ sitemap.php [L]
RewriteRule ^admin/?$ index.php?page=admin [R=301,L]
RewriteRule ^(config|includes|data|actions|docs|database|logs|storage)(/|$) - [F,L,NC]
RewriteRule ^assets/uploads/.*\.(php|phtml|phar|cgi|pl|py|sh)$ - [F,L,NC]
</IfModule>
