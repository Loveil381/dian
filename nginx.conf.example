# Nginx 服务器配置示例 - 魔女小店
# 将此配置调整后放入 /etc/nginx/sites-available/

upstream php_backend {
    server unix:/var/run/php-fpm.sock;
    # 或使用 TCP：server 127.0.0.1:9000;
}

server {
    listen 80;
    listen [::]:80;
    server_name example.com www.example.com;

    root /var/www/html/dian;
    index index.php;

    # 日志配置
    access_log /var/log/nginx/dian_access.log;
    error_log /var/log/nginx/dian_error.log;

    # 文件上传大小限制
    client_max_body_size 10M;

    # ── 安全响应头 ──
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # ── 静态资源缓存（1 年） ──
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|woff|woff2|ttf|svg)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # ── 阻止直接访问敏感目录 ──
    location ~ ^/(config|includes|data|actions|docs|database|logs)/ {
        return 403;
    }

    # ── 阻止在 uploads 目录执行 PHP ──
    location ~ ^/assets/uploads/.*\.php$ {
        return 403;
    }

    # ── 管理后台重定向（等同 RewriteRule ^admin/?$ index.php?page=admin） ──
    location = /admin {
        return 301 /index.php?page=admin;
    }
    location = /admin/ {
        return 301 /index.php?page=admin;
    }

    # ── PHP 处理 ──
    location ~ \.php$ {
        try_files $uri =404;
        fastcgi_pass php_backend;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
        # 防止 XSS
        fastcgi_param HTTP_PROXY "";
    }

    # ── 默认 index.php 路由（如果请求文件不存在） ──
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    # ── 禁止访问 .env, .git 等敏感文件 ──
    location ~ /\. {
        deny all;
    }

    # ── 启用 gzip 压缩 ──
    gzip on;
    gzip_types text/plain text/css application/json application/javascript;
    gzip_min_length 1000;

    # 可选：HTTPS 重定向（配置好 SSL 证书后取消注释）
    # listen 443 ssl http2;
    # ssl_certificate /etc/letsencrypt/live/example.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/example.com/privkey.pem;
}

# HTTP 到 HTTPS 重定向（可选）
# server {
#     listen 80;
#     server_name example.com www.example.com;
#     return 301 https://$server_name$request_uri;
# }
